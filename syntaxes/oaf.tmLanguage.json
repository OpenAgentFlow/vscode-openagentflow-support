{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "OpenAgentFlow",
  "scopeName": "source.oaf",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#properties"
    },
    {
      "include": "#decorators"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.oaf",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.oaf",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "patterns": [
            {
              "name": "constant.character.escape.oaf",
              "match": "\\\\([\\\\\"ntr]|u[0-9a-fA-F]{4})"
            }
          ]
        },
        {
          "name": "string.quoted.double.oaf",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.oaf",
              "match": "\\\\([\\\\\"ntr]|u[0-9a-fA-F]{4})"
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.declaration.oaf",
          "match": "\\b(workflow|agent|state|flow|config)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.oaf",
          "match": "\\b(string|int|float|bool|list|map)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.oaf",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.flow.oaf",
          "match": "\\b(start|end)\\b"
        },
        {
          "name": "constant.numeric.float.oaf",
          "match": "\\b-?[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.oaf",
          "match": "\\b-?[0-9]+\\b"
        }
      ]
    },
    "properties": {
      "patterns": [
        {
          "name": "support.variable.property.agent.oaf",
          "match": "\\b(instructions|model|provider|temperature|tools|inputs|outputs)(?=\\s*:)"
        },
        {
          "name": "support.variable.property.config.oaf",
          "match": "\\b(max_iterations|timeout_seconds|runtime|version)(?=\\s*:)"
        }
      ]
    },
    "decorators": {
      "patterns": [
        {
          "name": "storage.type.annotation.oaf",
          "match": "@[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.oaf",
          "match": "->"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.section.block.begin.oaf",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.block.end.oaf",
          "match": "\\}"
        },
        {
          "name": "punctuation.definition.brackets.begin.oaf",
          "match": "\\["
        },
        {
          "name": "punctuation.definition.brackets.end.oaf",
          "match": "\\]"
        },
        {
          "name": "punctuation.definition.parameters.begin.oaf",
          "match": "\\("
        },
        {
          "name": "punctuation.definition.parameters.end.oaf",
          "match": "\\)"
        },
        {
          "name": "punctuation.separator.key-value.oaf",
          "match": ":"
        },
        {
          "name": "punctuation.separator.comma.oaf",
          "match": ","
        }
      ]
    }
  }
}