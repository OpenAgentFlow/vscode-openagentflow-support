{
  "name": "openagentflow-support",
  "displayName": "OpenAgentFlow Support",
  "description": "Official VS Code language support for OpenAgentFlow (.oaf) — What OpenAPI is for REST APIs, OpenAgentFlow is for AI agent workflows.",
  "version": "0.0.5",
  "publisher": "openagentflow",
  "icon": "oaf-logo_128.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenAgentFlow/vscode-openagentflow-support.git"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "keywords": [
    "openagentflow",
    "oaf",
    "ai-agents",
    "multi-agent",
    "workflow",
    "langgraph",
    "dsl",
    "llm",
    "syntax-highlighting"
  ],
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "oaf",
        "aliases": [
          "OpenAgentFlow",
          "oaf"
        ],
        "extensions": [
          ".oaf",
          ".openagentflow"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "oaf",
        "scopeName": "source.oaf",
        "path": "./syntaxes/oaf.tmLanguage.json"
      }
    ]
  }
}
